# Секретный ключ Flask (сгенерируйте случайную строку)
SECRET_KEY=default-secret-key-change-me-please

# URL Центра Авторизации (https, если используется самоподписанный SSL)
CENTRAL_AUTH_URL=http://localhost:5001

# Токен для авторизации ноды
NODE_API_TOKEN=default-token-change-me-please

# Хост и порт для запуска панели
BIND_HOST=0.0.0.0
BIND_PORT=5002

# Проверка SSL сертификата центра авторизации (false для самоподписанных)
VERIFY_SSL=false

# Путь к конфигурационному файлу Samba на хосте
SMB_CONF_PATH=/etc/samba/smb.conf
